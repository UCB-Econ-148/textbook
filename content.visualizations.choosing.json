ditrating.asp#toc-credit-ratings-scale","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"credit ratings","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"XE08mmsQ9x"}],"urlSource":"https://www.investopedia.com/terms/c/creditrating.asp#toc-credit-ratings-scale","key":"K7ueRv8HKl"},{"type":"text","value":", income classes (low, middle or high), the ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"Ne38f81RC4"},{"type":"link","url":"https://hdr.undp.org/data-center/human-development-index#/indicies/HDI","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"HDI","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"JFHoAyAj7D"}],"urlSource":"https://hdr.undp.org/data-center/human-development-index#/indicies/HDI","key":"bEnzoON3o5"},{"type":"text","value":", etc.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"PKRoXLTi5A"}],"key":"PaQqwdNCIT"}],"key":"QfqNEifTz6"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Qualitative Nominal:","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"kNzhcCqDPn"}],"key":"SleGXFxpvk"},{"type":"text","value":" Qualitative nominal variables represent categories or groups with no inherent order or ranking. They are distinct and unrelated categories. Economic examples include the various types of industries, the names of various currencies, the names of countries in a trade agreement, etc.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"Q8NX7zgZyD"}],"key":"QcsAYBLZtt"}],"key":"GPlHFILH5n"}],"key":"N61gmzcBav"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"strong","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Important Note:","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"eGTtyFxbvi"}],"key":"Zk4FlW6TxE"},{"type":"text","value":" Be careful between quantitative discrete and qualitative ordinal variables in particular. For example, someone may argue that the ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"uYrm59Fg7R"},{"type":"link","url":"https://hdr.undp.org/data-center/human-development-index#/indicies/HDI","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"HDI","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"O5dJ8I8zFO"}],"urlSource":"https://hdr.undp.org/data-center/human-development-index#/indicies/HDI","key":"bwV7grjLZd"},{"type":"text","value":" is a quantitative discrete variable. However, the difference between countries with HDIs of 0.9 vs 0.7 is not necessairly the same as the difference between countries with HDIs of 0.7 vs 0.5, something that we would expect from a quantitative variable. In other words, for the HDI, intervals between the categories are not necessarily uniform or well-defined. Another example of a confusing variable could be a child’s grade/year in school, where the difference between grade 12 and grade 8 is not necessairly the same as the difference between grade 8 and grade 4.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"eAsiMpfJWG"}],"key":"WEyBQKFlGL"}],"key":"wMhWYdRGB2"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"General Guide","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AP1rUtSQuR"}],"identifier":"general-guide","label":"General Guide","html_id":"general-guide","implicit":true,"key":"SzQIslZUdK"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Below, we’ve included a general guide on which kind of plot to use when plotting different variable types. While we simply suggest which plots to make here, the next two subchapters elaborate on these types of plots in more detail, read those if you have any questions. This guide is by no means comprehensive, and ultimately the kind of plot you should make depends on the data you need to visualize. For example, if you need to visualize differences between countries, a geographic plot may be better than any of the plots below.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"u3M0Q2ViOP"}],"key":"SoYUEmviJx"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If you are plotting two quantitative continuous variables, a scatter plot or 2D KDE plot could be helpful.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"dsBLaLof78"}],"key":"p5dlTTV7LC"}],"key":"iPzmaIHW9K"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If you are plotting a qualitative variable and a quantitative continuous variable, overlaid histograms or side-by-side box/violinplots could be helpful.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"v2VWIWmRUe"}],"key":"HgRvDt3bnC"}],"key":"UAfBqL5i26"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If you are plotting a qualitative variable and a quantitative discrete variable, a bar chart could be helpful.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"hTDolvUprA"}],"key":"SLgt5DSmXG"}],"key":"tTFat79HZs"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"If you are plotting time data, a line plot could be helpful.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"EtEkJTrXw9"}],"key":"Qn14l8luwv"}],"key":"a4bVSrxvc8"}],"key":"potc3ZSeAu"}],"key":"STg3CyhE7T"}],"key":"LyUcROdXhl"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Visualizations","url":"/content/visualizations","group":"Python for Economists"},"next":{"title":"Basic Visualizations","url":"/content/visualizations/types","group":"Python for Economists"}}},"domain":"http://localhost:3000"}