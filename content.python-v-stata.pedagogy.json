{"version":3,"kind":"Notebook","sha256":"7bcebd28286eccb229eae1964245a3ffce7db8fa05339b5e5a91ff71f573fa83","slug":"content.python-v-stata.pedagogy","location":"/content/01-python_v_stata/pedagogy.ipynb","dependencies":[],"frontmatter":{"title":"Economics Pedagogy","content_includes_title":false,"kernelspec":{"name":"conda-env-sklearn-env-py","display_name":"Python [conda env:sklearn-env]","language":"python"},"authors":[{"nameParsed":{"literal":"Rohan Jha","given":"Rohan","family":"Jha"},"name":"Rohan Jha","id":"contributors-myst-generated-uid-0"}],"copyright":"2024","numbering":{"title":{"offset":1}},"exports":[{"format":"ipynb","filename":"pedagogy.ipynb","url":"/build/pedagogy-02fbdfed63a82919fbbfbe9855780ade.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Both Python and Stata have been used to teach economics to students of all levels, from the beginner to the graduate students. They both have their advantages and disadvantages, some of which are discussed below.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"L4RYtOCthD"}],"key":"hr3wPbMyrh"}],"key":"nZF7ZqXxKS"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Learning Curve","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"EPuetHiIWd"}],"identifier":"learning-curve","label":"Learning Curve","html_id":"learning-curve","implicit":true,"key":"QE27ambmI4"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Students who have little to no experience in coding often find Stata’s command-line interface easier to install and use. However, students with more experience in coding may be more familiar with Python and thus find that easier to use. At the end of the day, different students could find either of the softwares easier to learn, and the software you choose to use should consider the level of the students in your class.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ee8nUKwf0C"}],"key":"eHvfVw1KIP"}],"key":"fqsve0ayw0"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Accessibility","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HnQxBNtSq1"}],"identifier":"accessibility","label":"Accessibility","html_id":"accessibility","implicit":true,"key":"LPsJplFhCk"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Both Python and Jupyter notebooks are free and easily accessible, while Stata must be purchased. If your students do not have an instituional license for Stata, it may be more inclusive to use Python to avoid placing an undue financial burden on students.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oFOFk1yVrh"}],"key":"z17p1x3XNi"}],"key":"aXd4bSow4R"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Cloud Computing","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"owTSY3B5pl"}],"identifier":"cloud-computing","label":"Cloud Computing","html_id":"cloud-computing","implicit":true,"key":"TWtQMEeYIQ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"With the great integration between Jupyter Notebooks and Cloud Computing provided by tools such as ","position":{"start